#!/usr/bin/env bash
# YAAT Dotfiles - Main Entrypoint
# Applies dotfiles with YAAT and reloads runtime components

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

REPO="${DOTFILES_REPO:-$HOME/.dotfiles}"
YAAT_BIN="${YAAT_BIN:-yaat}"
HOST=""
DRY_RUN=0

usage() {
    cat <<'EOF'
Usage: apply-dotfiles [--host <name>] [--dry-run] [--help]

Options:
  --host <name>     Use specific host (skips prompt)
  --dry-run         Preview changes without applying
  --help            Show this help

Environment:
  DOTFILES_HOST     Override auto-detection
  DOTFILES_REPO     Path to dotfiles repo (default: ~/.dotfiles)
  YAAT_BIN          YAAT binary path (default: yaat)

Examples:
  apply-dotfiles                    # Interactive host selection
  apply-dotfiles --host desktop     # Use desktop directly
  apply-dotfiles --dry-run          # Preview only
EOF
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --host)
            HOST="${2:-}"
            [[ -n "$HOST" ]] || { log_error "--host requires value"; exit 2; }
            shift 2
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            log_error "Unknown argument: $1"
            usage >&2
            exit 2
            ;;
    esac
done

# Validations
[[ -d "$REPO" ]] || { log_error "Repo not found: $REPO"; exit 1; }

# Check YAAT is installed
if ! command -v "$YAAT_BIN" >/dev/null 2>&1; then
    log_error "YAAT not found: $YAAT_BIN"
    echo ""
    echo "YAAT is required but not installed. Install it with:"
    echo ""
    echo "  # Directly from GitHub (easiest):"
    echo "  cargo install --git https://github.com/mhernandezve/yaat"
    echo ""
    echo "  # Or clone and install manually:"
    echo "  git clone https://github.com/mhernandezve/yaat.git /tmp/yaat"
    echo "  cd /tmp/yaat"
    echo "  cargo install --path ."
    echo ""
    echo "  # Or download pre-built binary (if available):"
    echo "  curl -L https://github.com/mhernandezve/yaat/releases/latest/download/yaat-linux-x64 -o ~/.local/bin/yaat"
    echo "  chmod +x ~/.local/bin/yaat"
    echo ""
    exit 1
fi

# Determine host (priority: CLI > ENV > auto-detect > prompt)
if [[ -z "$HOST" ]]; then
    if [[ -n "${DOTFILES_HOST:-}" ]]; then
        HOST="$DOTFILES_HOST"
        log_info "Using DOTFILES_HOST: $HOST"
    else
        HOST="$($SCRIPT_DIR/detect-host.sh)"
    fi
    
    # Prompt for host (simplified: show default, Enter accepts, type to change)
    read -p "Host [$HOST]: " input
    HOST="${input:-$HOST}"
fi

log_info "Repo: $REPO"
log_info "Host: $HOST"
[[ "$DRY_RUN" -eq 1 ]] && log_info "Mode: DRY-RUN"

# Export for sub-scripts
export DRY_RUN HOST REPO

# PHASE 1: Sync with YAAT
log_info "Running YAAT sync..."
sync_args=("--host" "$HOST")
[[ "$DRY_RUN" -eq 1 ]] && sync_args+=("--dry-run")

YAAT_REPO="$REPO" "$YAAT_BIN" sync "${sync_args[@]}"

# PHASE 2: Apply runtime (skip in dry-run to avoid side effects)
if [[ "$DRY_RUN" -eq 1 ]]; then
    log_info "Skipping runtime scripts in dry-run mode"
else
    PLATFORM=$(detect_platform)
    RUNTIME_DIR="$SCRIPT_DIR/runtime/$PLATFORM"

    if [[ -d "$RUNTIME_DIR" ]]; then
        log_info "Applying runtime configurations for $PLATFORM..."

        for script in "$RUNTIME_DIR/"*.sh; do
            [[ -f "$script" ]] || continue

            script_name=$(basename "$script")
            log_info "Running: $script_name"

            if "$script"; then
                log_info "✓ $script_name completed"
            else
                log_warn "✗ $script_name failed (continuing...)"
            fi
        done
    fi
fi

log_info "Done!"
